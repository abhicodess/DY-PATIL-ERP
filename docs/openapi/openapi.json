  "info": {
    "title": "DY Patil University ERP API",
    "version": "v1"
  },
  "tags": [
    {
      "name": "auth_api_v1",
      "description": "Authentication and Session endpoints"
    },
    {
      "name": "students_api_v1",
      "description": "Student management endpoints"
    },
    {
      "name": "attendance_api_v1",
      "description": "Attendance management endpoints"
    },
    {
      "name": "changelog",
      "description": "API Changelog endpoints"
    }
  ],
  "openapi": "3.1.0",
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Error code"
          },
          "status": {
            "type": "string",
            "description": "Error name"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "errors": {
            "type": "object",
            "description": "Errors"
          }
        }
      },
      "PaginationMetadata": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "total_pages": {
            "type": "integer"
          },
          "first_page": {
            "type": "integer"
          },
          "last_page": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "previous_page": {
            "type": "integer"
          },
          "next_page": {
            "type": "integer"
          }
        }
      },
      "CSRFResponse": {
        "type": "object",
        "properties": {
          "csrf_token": {
            "type": "string"
          }
        },
        "required": [
          "csrf_token"
        ]
      },
      "Login": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "faculty",
              "student"
            ]
          }
        },
        "required": [
          "password",
          "role",
          "username"
        ]
      },
      "Error1": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Not found"
          },
          "code": {
            "type": "string",
            "example": "STUDENT_NOT_FOUND"
          },
          "details": {
            "type": [
              "object",
              "null"
            ],
            "default": null
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "department": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "refresh_token": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserProfile"
          }
        },
        "required": [
          "access_token",
          "refresh_token",
          "user"
        ]
      },
      "RefreshResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          }
        },
        "required": [
          "access_token"
        ]
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "total": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "per_page": {
            "type": "integer"
          },
          "pages": {
            "type": "integer"
          },
          "has_next": {
            "type": "boolean"
          },
          "has_prev": {
            "type": "boolean"
          }
        }
      },
      "StudentResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "roll": {
            "type": "string"
          },
          "department": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          },
          "division": {
            "type": "string"
          },
          "semester": {
            "type": "integer"
          },
          "phone": {
            "type": "string"
          },
          "attendance_pct": {
            "type": "number",
            "default": 0.0,
            "description": "Current month attendance %"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "StudentCreate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "roll": {
            "type": "string",
            "example": "CS2024001"
          },
          "department": {
            "type": "string",
            "enum": [
              "CS",
              "IT",
              "ENTC",
              "MECH",
              "CIVIL",
              "AIDS",
              "AIML"
            ]
          },
          "year": {
            "type": "integer",
            "minimum": 1,
            "maximum": 4
          },
          "division": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C",
              "D"
            ]
          },
          "semester": {
            "type": "integer",
            "minimum": 1,
            "maximum": 8
          },
          "dob": {
            "type": "string",
            "format": "date"
          },
          "phone": {
            "type": "string",
            "pattern": "^\\+?[0-9]{10,13}$"
          },
          "parent_phone": {
            "type": "string",
            "pattern": "^\\+?[0-9]{10,13}$"
          },
          "address": {
            "type": "string",
            "maxLength": 500
          }
        },
        "required": [
          "department",
          "division",
          "dob",
          "email",
          "name",
          "roll",
          "semester",
          "year"
        ]
      },
      "StudentUpdate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "address": {
            "type": "string"
          }
        }
      },
      "AttendanceSummary": {
        "type": "object",
        "properties": {
          "student_id": {
            "type": "integer"
          },
          "student_name": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "attended": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          },
          "percentage": {
            "type": "number"
          }
        }
      },
      "ResultResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "student_id": {
            "type": "integer"
          },
          "semester": {
            "type": "string"
          },
          "subject_id": {
            "type": "integer"
          },
          "internal_marks": {
            "type": "number"
          },
          "external_marks": {
            "type": "number"
          },
          "total": {
            "type": "number"
          },
          "grade": {
            "type": "string"
          },
          "is_published": {
            "type": "boolean"
          }
        }
      },
      "AttendanceRecord": {
        "type": "object",
        "properties": {
          "student_id": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": [
              "Present",
              "Absent",
              "Late",
              "Excused",
              "Leave"
            ]
          },
          "remark": {
            "type": "string",
            "default": ""
          }
        },
        "required": [
          "status",
          "student_id"
        ]
      },
      "AttendanceSubmit": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "time_slot": {
            "type": "string"
          },
          "division": {
            "type": "string"
          },
          "semester": {
            "type": "string"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AttendanceRecord"
            }
          }
        },
        "required": [
          "date",
          "division",
          "records",
          "semester",
          "subject",
          "time_slot"
        ]
      },
      "ErrorSchema": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Not found"
          },
          "code": {
            "type": "string",
            "example": "STUDENT_NOT_FOUND"
          },
          "details": {
            "type": [
              "object",
              "null"
            ],
            "default": null
          }
        }
      }
    },
    "responses": {
      "DEFAULT_ERROR": {
        "description": "Default error response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "UNPROCESSABLE_ENTITY": {
        "description": "Unprocessable Entity",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "UnauthorizedError": {
        "description": "JWT missing or invalid",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorSchema"
            }
          }
        }
      },
      "ForbiddenError": {
        "description": "Insufficient role permissions",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorSchema"
            }
          }
        }
      },
      "TenantMismatchError": {
        "description": "JWT tenant does not match request subdomain",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorSchema"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}