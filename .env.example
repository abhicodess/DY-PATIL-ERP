# ================================================
# NEVER commit .env to version control.
# Copy this file: cp .env.example .env
# Generate SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Generate JWT_SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ================================================

# Flask Core Configuration
# REQUIRED — generate with command above and insert here (min 32 chars)
SECRET_KEY=change-me-use-a-strong-secret-key-at-least-32-chars-long
# REQUIRED — generate with command above and insert here (min 32 chars)
JWT_SECRET_KEY=change-me-use-a-strong-jwt-secret-key-at-least-32-chars-long
FLASK_APP=app:create_app()
FLASK_ENV=production
DEBUG=false   # set to true ONLY for local development
PORT=8000

# Sentry Monitoring
SENTRY_DSN=https://placeholder_sentry_dsn@sentry.io/123456

# Database Configuration (PostgreSQL)
POSTGRES_USER=change-me-use-a-secure-database-username
POSTGRES_PASSWORD=change-me-use-a-strong-password-here
POSTGRES_DB=change-me-use-a-secure-database-name
PG_URL=postgresql://change-me-use-a-secure-database-username:change-me-use-a-strong-password-here@db:5432/change-me-use-a-secure-database-name
DATABASE_URL=postgresql://change-me-use-a-secure-database-username:change-me-use-a-strong-password-here@db:5432/change-me-use-a-secure-database-name
DB_POOL_MAX=20

# Redis & Celery Configuration
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ERP Authentication Defaults
ADMIN_PASSWORD=change-me-use-a-strong-admin-password
ADMIN_PASSWORD_HASH=change-me-use-a-strong-admin-password-hash
ADMIN_PHONE=+1234567890
DEFAULT_STUDENT_PASSWORD=change-me-use-a-strong-student-password
DEFAULT_FACULTY_PASSWORD=change-me-use-a-strong-faculty-password

# External Service Providers (Twilio, SendGrid, Firebase)
SMS_PROVIDER=twilio
TWILIO_SID=change-me-use-a-valid-twilio-sid
TWILIO_AUTH_TOKEN=change-me-use-a-valid-twilio-token
TWILIO_NUMBER=+1234567890
SENDGRID_API_KEY=change-me-use-a-valid-sendgrid-key
FCM_SERVER_KEY=change-me-use-a-valid-fcm-key

# Cloud Storage Configuration (AWS S3)
AWS_ACCESS_KEY_ID=change-me-use-a-valid-aws-key
AWS_SECRET_ACCESS_KEY=change-me-use-a-valid-aws-secret
AWS_S3_BUCKET=dypatil-erp-uploads

# File Upload Folder
UPLOAD_PATH=uploads

# Security Policies
ENFORCE_MFA=false
ENFORCE_SSL=false

# Gunicorn Options
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=4
GUNICORN_LOGLEVEL=info

# ERP Constants
ATTENDANCE_LOCK_HOURS=24

# Grafana Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-use-a-strong-password-here
